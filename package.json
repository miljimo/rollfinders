{
  "name": "rollfinder",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev apps/portal",
    "build": "next build apps/portal",
    "start": "next start apps/portal",
    "start:standalone": "node apps/portal/.next/standalone/apps/portal/server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test": "npm run typecheck && npm run test:unit",
    "test:unit": "node --import tsx --test \"apps/portal/src/components/{Button,GridDashboard,QuickActionPanel,StatsPanel,Table,data-table-with-search,pagination,tab-control}/__tests__/*.test.tsx\" \"apps/portal/src/components/__tests__/*.test.tsx\" \"apps/portal/src/app/admin/__tests__/*.test.tsx\" \"apps/portal/src/lib/__tests__/*.test.ts\"",
    "payments:dev": "cd apps/backend_api && go run ./cmd/services/payments/api",
    "payments:test": "cd apps/backend_api && go test ./cmd/services/payments/... ./containers/payments/...",
    "payments:test:e2e": "cd apps/backend_api && RUN_PAYMENT_E2E=1 go test ./containers/payments/e2e -count=1 -v",
    "payments:compose": "cd apps/backend_api/containers/payments && docker compose -f compose.yml up -d",
    "services:build": "cd apps/backend_api && go list -f '{{if .GoFiles}}{{.ImportPath}}{{end}}' ./... | grep -v '^$' | xargs go build",
    "services:test": "cd apps/backend_api && go test ./...",
    "users:dev": "cd apps/backend_api && go run ./cmd/services/users/api",
    "users:test": "cd apps/backend_api && go test ./cmd/services/users/...",
    "users:compose": "cd apps/backend_api/containers/users && docker compose -f compose.yml up -d",
    "authorisation:dev": "cd apps/backend_api && go run ./cmd/services/authorisation/api",
    "authorisation:test": "cd apps/backend_api && go test ./cmd/services/authorisation/...",
    "authorisation:migrate-users": "cd apps/backend_api && go run ./cmd/services/authorisation/migrate-users-authorisation",
    "authorisation:compose": "cd apps/backend_api/containers/authorisation && docker compose -f compose.yml up -d",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "seed": "prisma db seed",
    "ensure-super-admin": "tsx prisma/ensure-super-admin.ts",
    "mobile:sync": "npm --workspace @rollfinders/mobile run sync",
    "mobile:doctor": "npm --workspace @rollfinders/mobile run doctor",
    "mobile:android:open": "npm --workspace @rollfinders/mobile run android:open",
    "mobile:android:apk": "npm --workspace @rollfinders/mobile run android:apk",
    "mobile:android:aab": "npm --workspace @rollfinders/mobile run android:aab",
    "mobile:ios:open": "npm --workspace @rollfinders/mobile run ios:open",
    "mobile:ios:sync": "npm --workspace @rollfinders/mobile run ios:sync"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
