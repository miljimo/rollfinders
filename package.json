{
  "name": "rollfinder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test": "npm run typecheck && npm run test:unit",
    "test:unit": "node --import tsx --test \"src/components/{Button,QuickActionPanel,StatsPanel,Table}/__tests__/*.test.tsx\" \"src/components/__tests__/*.test.tsx\" \"src/app/admin/__tests__/*.test.tsx\" \"src/lib/__tests__/*.test.ts\"",
    "payments:dev": "cd services/payments && go run ./cmd/api",
    "payments:test": "cd services/payments && go test ./...",
    "payments:test:e2e": "cd services/payments && RUN_PAYMENT_E2E=1 go test ./e2e -count=1 -v",
    "payments:compose": "cd services/payments && docker compose -f compose.yml up -d",
    "users:dev": "cd services/users && go run ./cmd/api",
    "users:test": "cd services/users && go test ./...",
    "users:compose": "cd services/users && docker compose -f compose.yml up -d",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "seed": "prisma db seed",
    "ensure-super-admin": "tsx prisma/ensure-super-admin.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1061.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
