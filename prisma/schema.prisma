generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  STANDARD_USER
  ACADEMY_OWNER
  PLATFORM_ADMIN
  SUPER_ADMIN
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum GiType {
  GI
  NO_GI
  BOTH
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AcademyMemberRole {
  OWNER
  ADMIN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(STANDARD_USER)
  status       UserStatus @default(ACTIVE)
  disabled     Boolean  @default(false)
  isProtected  Boolean  @default(false) @map("is_protected")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  academyMemberships AcademyMember[]
  academyInvitations AcademyInvitation[] @relation("AcademyInvitationInviter")
  adminAuditLogs AdminAuditLog[] @relation("AdminAuditLogActor")
  targetedAdminAuditLogs AdminAuditLog[] @relation("AdminAuditLogTarget")

  @@map("users")
}

model Academy {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String
  affiliation String?
  website     String?
  email       String?
  phone       String?
  address     String
  city        String
  postcode    String
  borough     String?
  country     String         @default("United Kingdom")
  latitude    Float
  longitude   Float
  logoUrl     String?        @map("logo_url")
  dropInPrice Float?         @map("drop_in_price")
  giAvailable Boolean        @default(true) @map("gi_available")
  nogiAvailable Boolean      @default(true) @map("nogi_available")
  beginnerFriendly Boolean   @default(true) @map("beginner_friendly")
  competitionFocused Boolean @default(false) @map("competition_focused")
  verified    Boolean        @default(false)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  events      Event[]
  claims      ClaimRequest[]
  members     AcademyMember[]
  invitations AcademyInvitation[]

  @@index([city])
  @@index([postcode])
  @@map("academies")
}

model Event {
  id          String   @id @default(cuid())
  academyId   String   @map("academy_id")
  title       String
  description String
  eventDate   DateTime @map("event_date")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  giType      GiType   @map("gi_type")
  price       Decimal  @db.Decimal(8, 2)
  capacity    Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  academy     Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([eventDate])
  @@map("events")
}

model ClaimRequest {
  id             String      @id @default(cuid())
  academyId      String      @map("academy_id")
  requesterName  String      @map("requester_name")
  requesterEmail String      @map("requester_email")
  status         ClaimStatus @default(PENDING)
  createdAt      DateTime    @default(now()) @map("created_at")
  academy        Academy     @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("claim_requests")
}

model AcademyMember {
  id        String            @id @default(cuid())
  academyId String           @map("academy_id")
  userId    String           @map("user_id")
  role      AcademyMemberRole
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  academy   Academy          @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([academyId, userId])
  @@index([userId])
  @@map("academy_members")
}

model AcademyInvitation {
  id           String           @id @default(cuid())
  academyId    String          @map("academy_id")
  invitedEmail String          @map("invited_email")
  invitedById  String          @map("invited_by")
  token        String          @unique
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime        @map("expires_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  academy      Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  invitedBy    User            @relation("AcademyInvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([academyId])
  @@index([invitedEmail])
  @@map("academy_invitations")
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String   @map("actor_user_id")
  targetUserId String?  @map("target_user_id")
  action       String
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  actor        User     @relation("AdminAuditLogActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target       User?    @relation("AdminAuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@map("admin_audit_logs")
}
