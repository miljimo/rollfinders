generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  STANDARD_USER
  ACADEMY_OWNER
  ACADEMY_ADMIN
  PLATFORM_ADMIN
  SUPER_ADMIN
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum GiType {
  GI
  NO_GI
  BOTH
}

enum RecurrenceType {
  NONE
  WEEKLY
  MONTHLY
  YEARLY
}

enum EventAudience {
  EXTERNAL_ONLY
  EXTERNAL_AND_MEMBERS
}

enum EventPricingType {
  FIXED
  FREE
  DONATION
}

enum CourseType {
  OPEN_MAT
  TRAINING
  SPARRING
  SEMINAR
  WORKSHOP
  COMPETITION
  PRIVATE_LESSON
}

enum CourseActivityType {
  WARM_UP
  DRILLING
  TECHNICAL
  ROLLING
  SPARRING
  COMPETITION
  Q_AND_A
  BREAK
  LUNCH
  DINNER
  SOCIAL
  CUSTOM
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClaimRequesterRole {
  OWNER
  HEAD_COACH
  MANAGER
  STAFF
  OTHER
}

enum BjjBeltRank {
  WHITE
  BLUE
  PURPLE
  BROWN
  BLACK
  CORAL
  RED
  OTHER
}

enum AcademyVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AcademySocialPlatform {
  FACEBOOK
  INSTAGRAM
  X
  YOUTUBE
  TIKTOK
  LINKEDIN
  WEBSITE
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

enum PlatformAdminActivityAction {
  ACADEMY_CREATED
  OPEN_MAT_CREATED
  ACADEMY_ADMIN_ACTIVATED
}

enum PlatformAdminActivitySource {
  ACADEMY
  OPEN_MAT
  ACADEMY_ADMIN
}

enum PlatformAdminExemptionType {
  TEMPORARY
  PERMANENT
}

model Academy {
  id                 String                    @id @default(cuid())
  name               String
  slug               String                    @unique
  description        String
  affiliation        String?
  website            String?
  email              String?
  phone              String?
  address            String
  city               String
  postcode           String
  borough            String?
  country            String                    @default("United Kingdom")
  latitude           Float
  longitude          Float
  logoUrl            String?                   @map("logo_url")
  coverImageUrl      String?                   @map("cover_image_url")
  categories         String?
  facebookUrl        String?                   @map("facebook_url")
  instagramUrl       String?                   @map("instagram_url")
  xUrl               String?                   @map("x_url")
  dropInPrice        Float?                    @map("drop_in_price")
  giAvailable        Boolean                   @default(true) @map("gi_available")
  nogiAvailable      Boolean                   @default(true) @map("nogi_available")
  beginnerFriendly   Boolean                   @default(true) @map("beginner_friendly")
  competitionFocused Boolean                   @default(false) @map("competition_focused")
  verificationStatus AcademyVerificationStatus @default(PENDING) @map("verification_status")
  featured           Boolean                   @default(false)
  verified           Boolean                   @default(false)
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  createdById        String?                   @map("created_by_id")
  events             Event[]
  claims             ClaimRequest[]
  members            AcademyMember[]
  invitations        AcademyInvitation[]
  claimReminders     AcademyClaimReminder[]
  socialLinks        AcademySocialLink[]
  analyticsEvents    AnalyticsEvent[]
  analyticsMetrics   AnalyticsDailyMetric[]
  paymentAccounts    PaymentAccountSetting[]

  @@index([city])
  @@index([postcode])
  @@index([name])
  @@index([verificationStatus])
  @@index([featured])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([createdById])
  @@map("academies")
}

model PaymentAccountSetting {
  id                String   @id @default(cuid())
  ownerType         String   @map("owner_type")
  ownerId           String   @map("owner_id")
  academyId         String?  @map("academy_id")
  provider          String   @default("stripe")
  providerAccountId String?  @map("provider_account_id")
  status            String   @default("pending")
  chargesEnabled    Boolean  @default(false) @map("charges_enabled")
  payoutsEnabled    Boolean  @default(false) @map("payouts_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  academy           Academy? @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@unique([ownerType, ownerId, provider])
  @@index([academyId])
  @@index([ownerType, ownerId])
  @@index([providerAccountId])
  @@map("payment_account_settings")
}

model PaymentPlatformSetting {
  id                             String   @id
  platformFeeBasisPoints          Int      @default(500) @map("platform_fee_basis_points")
  platformFeeFixedMinor           Int      @default(0) @map("platform_fee_fixed_minor")
  stripeProcessingFeeBasisPoints  Int      @default(290) @map("stripe_processing_fee_basis_points")
  stripeProcessingFeeFixedMinor   Int      @default(30) @map("stripe_processing_fee_fixed_minor")
  currency                       String   @default("GBP")
  createdAt                      DateTime @default(now()) @map("created_at")
  updatedAt                      DateTime @updatedAt @map("updated_at")

  @@map("payment_platform_settings")
}

model AcademySocialLink {
  id        String                @id @default(cuid())
  academyId String                @map("academy_id")
  platform  AcademySocialPlatform
  url       String
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")
  academy   Academy               @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@unique([academyId, platform])
  @@index([academyId])
  @@map("academy_social_links")
}

model Event {
  id                 String                 @id @default(cuid())
  academyId          String                 @map("academy_id")
  createdById        String?                @map("created_by_id")
  title              String
  description        String
  eventDate          DateTime               @map("event_date")
  startTime          String                 @map("start_time")
  endTime            String                 @map("end_time")
  giType             GiType                 @map("gi_type")
  price              Decimal                @db.Decimal(8, 2)
  pricingType        EventPricingType       @default(FIXED) @map("pricing_type")
  donationLabel      String?                @map("donation_label")
  audience           EventAudience          @default(EXTERNAL_ONLY)
  courseType         CourseType             @default(OPEN_MAT) @map("course_type")
  instructor         String?
  contactEmail       String?                @map("contact_email")
  contactPhone       String?                @map("contact_phone")
  locationName       String?                @map("location_name")
  addressOverride    String?                @map("address_override")
  capacity           Int?
  active             Boolean                @default(true)
  recurrenceType     RecurrenceType         @default(NONE) @map("recurrence_type")
  recurrenceInterval Int                    @default(1) @map("recurrence_interval")
  recurrenceEndDate  DateTime?              @map("recurrence_end_date")
  recurrenceLimit    Int?                   @map("recurrence_limit")
  createdAt          DateTime               @default(now()) @map("created_at")
  academy            Academy                @relation(fields: [academyId], references: [id], onDelete: Cascade)
  activities         CourseActivity[]
  analyticsEvents    AnalyticsEvent[]
  analyticsMetrics   AnalyticsDailyMetric[]

  @@index([eventDate])
  @@index([academyId])
  @@index([createdById])
  @@index([courseType])
  @@index([recurrenceType])
  @@index([recurrenceEndDate])
  @@map("events")
}

model CourseActivity {
  id           String             @id @default(cuid())
  courseId     String             @map("course_id")
  name         String
  activityType CourseActivityType @map("activity_type")
  startTime    String             @map("start_time")
  endTime      String             @map("end_time")
  description  String?
  sortOrder    Int                @default(0) @map("sort_order")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  course       Event              @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, startTime])
  @@index([activityType])
  @@map("course_activities")
}

model ClaimRequest {
  id                   String             @id @default(cuid())
  academyId            String             @map("academy_id")
  requesterName        String             @map("requester_name")
  requesterEmail       String             @map("requester_email")
  requesterPhone       String?            @map("requester_phone")
  requesterRole        ClaimRequesterRole @map("requester_role")
  requesterBeltRank    BjjBeltRank?       @map("requester_belt_rank")
  requesterBeltStripes Int?               @map("requester_belt_stripes")
  verificationNotes    String             @map("verification_notes")
  publicProofLink      String?            @map("public_proof_link")
  status               ClaimStatus        @default(PENDING)
  reviewedAt           DateTime?          @map("reviewed_at")
  reviewedById         String?            @map("reviewed_by_id")
  rejectionReason      String?            @map("rejection_reason")
  linkedUserId         String?            @map("linked_user_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  academy              Academy            @relation(fields: [academyId], references: [id], onDelete: Cascade)
  @@index([academyId])
  @@index([academyId, requesterEmail, status])
  @@index([status])
  @@index([reviewedById])
  @@index([linkedUserId])
  @@map("claim_requests")
}

model AcademyMember {
  id        String            @id @default(cuid())
  academyId String            @map("academy_id")
  userId    String            @map("user_id")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  academy   Academy           @relation(fields: [academyId], references: [id], onDelete: Cascade)
  @@unique([academyId, userId])
  @@index([userId])
  @@map("academy_members")
}

model AcademyInvitation {
  id           String           @id @default(cuid())
  academyId    String           @map("academy_id")
  invitedEmail String           @map("invited_email")
  invitedById  String           @map("invited_by")
  token        String           @unique
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime         @map("expires_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  academy      Academy          @relation(fields: [academyId], references: [id], onDelete: Cascade)
  @@index([academyId])
  @@index([invitedEmail])
  @@map("academy_invitations")
}

model AcademyClaimReminder {
  id              String   @id @default(cuid())
  academyId       String   @map("academy_id")
  actorUserId     String   @map("actor_user_id")
  recipientEmail  String?  @map("recipient_email")
  outboundEmailId String?  @map("outbound_email_id")
  idempotencyKey  String?  @map("idempotency_key")
  status          String
  skipReason      String?  @map("skip_reason")
  source          String   @default("admin_academies")
  createdAt       DateTime @default(now()) @map("created_at")
  academy         Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId, createdAt])
  @@index([recipientEmail, createdAt])
  @@index([status])
  @@index([skipReason])
  @@map("academy_claim_reminders")
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String   @map("actor_user_id")
  targetUserId String?  @map("target_user_id")
  action       String
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@map("admin_audit_logs")
}

model PlatformAdminProfile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  contributionOptIn Boolean  @default(true) @map("contribution_opt_in")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  @@map("platform_admin_profiles")
}

model PlatformAdminWeeklyTarget {
  id          String   @id @default(cuid())
  userId      String?  @unique @map("user_id")
  targetCount Int      @map("target_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("platform_admin_weekly_targets")
}

model PlatformAdminActivityExemption {
  id          String                     @id @default(cuid())
  userId      String                     @map("user_id")
  type        PlatformAdminExemptionType
  reason      String?
  startsAt    DateTime                   @default(now()) @map("starts_at")
  endsAt      DateTime?                  @map("ends_at")
  createdById String?                    @map("created_by_id")
  createdAt   DateTime                   @default(now()) @map("created_at")
  @@index([userId, type, startsAt, endsAt])
  @@index([createdById])
  @@map("platform_admin_activity_exemptions")
}

model PlatformAdminActivityEvent {
  id          String                      @id @default(cuid())
  actorUserId String                      @map("actor_user_id")
  actionType  PlatformAdminActivityAction @map("action_type")
  sourceType  PlatformAdminActivitySource @map("source_type")
  sourceId    String                      @map("source_id")
  points      Int
  occurredAt  DateTime                    @default(now()) @map("occurred_at")
  createdAt   DateTime                    @default(now()) @map("created_at")
  dedupeKey   String                      @unique @map("dedupe_key")
  metadata    Json?
  @@index([actorUserId, occurredAt])
  @@index([actionType, occurredAt])
  @@index([sourceType, sourceId])
  @@map("platform_admin_activity_events")
}

model AnalyticsVisitor {
  id             String           @id @map("visitor_id")
  lastSessionId  String?          @map("last_session_id")
  ipHash         String?          @map("ip_hash")
  userAgentHash  String?          @map("user_agent_hash")
  firstSeenAt    DateTime         @default(now()) @map("first_seen_at")
  lastSeenAt     DateTime         @default(now()) @map("last_seen_at")
  sessionSeenAt  DateTime?        @map("session_seen_at")
  metadata       Json?
  events         AnalyticsEvent[]

  @@index([lastSeenAt])
  @@index([lastSessionId])
  @@map("analytics_visitors")
}

model AnalyticsEvent {
  id        String            @id @default(cuid())
  eventName String            @map("event_name")
  visitorId String?           @map("visitor_id")
  sessionId String?           @map("session_id")
  ipHash    String?           @map("ip_hash")
  academyId String?           @map("academy_id")
  openMatId String?           @map("open_mat_id")
  countryCode String?          @map("country_code")
  countryName String?          @map("country_name")
  source    String
  metadata  Json?
  createdAt DateTime          @default(now()) @map("created_at")
  visitor   AnalyticsVisitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  academy   Academy?          @relation(fields: [academyId], references: [id], onDelete: SetNull)
  openMat   Event?            @relation(fields: [openMatId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([visitorId, createdAt])
  @@index([academyId, createdAt])
  @@index([openMatId, createdAt])
  @@index([countryCode, createdAt])
  @@index([createdAt])
  @@map("analytics_events")
}

model AnalyticsDailyMetric {
  id           String    @id @default(cuid())
  metricDate   DateTime  @map("metric_date") @db.Date
  metricName   String    @map("metric_name")
  source       String?
  academyId    String?   @map("academy_id")
  openMatId    String?   @map("open_mat_id")
  dimensionKey String    @default("global") @map("dimension_key")
  dimensions   Json?
  value        Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  academy      Academy?  @relation(fields: [academyId], references: [id], onDelete: SetNull)
  openMat      Event?    @relation(fields: [openMatId], references: [id], onDelete: SetNull)

  @@unique([metricDate, metricName, dimensionKey])
  @@index([metricDate])
  @@index([metricName, metricDate])
  @@index([academyId, metricDate])
  @@index([openMatId, metricDate])
  @@map("analytics_daily_metrics")
}
